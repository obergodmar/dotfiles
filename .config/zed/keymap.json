[
  {
    "context": "Workspace || Editor",
    "bindings": {
      "ctrl-\\": "terminal_panel::Toggle",
      "ctrl-f": "workspace::ToggleZoom",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "ctrl-left": "workspace::ActivatePaneLeft",
      "ctrl-down": "workspace::ActivatePaneDown",
      "ctrl-up": "workspace::ActivatePaneUp",
      "ctrl-right": "workspace::ActivatePaneRight",
      "alt-left": "vim::ResizePaneLeft",
      "alt-down": "vim::ResizePaneDown",
      "alt-up": "vim::ResizePaneUp",
      "alt-right": "vim::ResizePaneRight",
      "space tab": "workspace::ToggleLeftDock",
      "space backspace": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Editor && mode == full && vim_mode == normal",
    "bindings": {
      "enter": ["workspace::SendKeystrokes", "*"],
      "space f": "editor::Format",
      "space F": "project_panel::ToggleFocus",
      "space e": "editor::Hover",
      "space c a": "editor::ToggleCodeActions",
      "space c r": "editor::Rename",
      "space c s": "command_palette::Toggle",
      "space c p": "workspace::CopyRelativePath",
      "space c f": "workspace::CopyPath",
      "space c l": "editor::CopyFileLocation",
      "space t a": "workspace::NewFile",
      "space t c": "pane::CloseActiveItem",
      "space t o": "pane::CloseOtherItems",
      "space t n": "pane::ActivateNextItem",
      "space t p": "pane::ActivatePreviousItem",
      "space s f": "file_finder::Toggle",
      "space s G": "pane::DeploySearch",
      "space s d": "diagnostics::Deploy",
      "space s s": "git_panel::Toggle",
      "space h p": "editor::ToggleSelectedDiffHunks",
      "space h s": "git::ToggleStaged",
      "space h r": "git::Restore",
      "space h d": "git::Diff",
      "space b": "git::Blame",
      "space B": "git::FileHistory",
      "space ?": "file_finder::Toggle",
      "space y": ["workspace::SendKeystrokes", "\" + y"],
      "space Y": ["workspace::SendKeystrokes", "\" + y g _"],
      "space p": ["workspace::SendKeystrokes", "\" + p"],
      "space P": ["workspace::SendKeystrokes", "\" + P"],
      "space н": ["workspace::SendKeystrokes", "\" + y"],
      "space Н": ["workspace::SendKeystrokes", "\" + y g _"],
      "space з": ["workspace::SendKeystrokes", "\" + p"],
      "space З": ["workspace::SendKeystrokes", "\" + P"],
      "[ d": "editor::GoToPreviousDiagnostic",
      "] d": "editor::GoToDiagnostic",
      "[ c": "editor::GoToPreviousHunk",
      "] c": "editor::GoToHunk",
      "g r": "editor::FindAllReferences",
      "K": "editor::Hover",
    },
  },
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-z": "editor::ShowCompletions",
      "escape": ["workspace::SendKeystrokes", "escape : nohl enter"],
      "shift-tab": "editor::AcceptEditPrediction",
    },
  },
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      ">": "editor::Indent",
      "<": "editor::Outdent",
      "space y": ["workspace::SendKeystrokes", "\" + y"],
      "space p": ["workspace::SendKeystrokes", "\" + p"],
      "space P": ["workspace::SendKeystrokes", "\" + P"],
      "space h s": "git::ToggleStaged",
    },
  },
  {
    "context": "VimControl && !menu",
    "unbind": {
      "g space": "editor::OpenExcerpts",
    },
  },
]
