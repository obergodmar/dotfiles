{
  "cli_default_open_behavior": "existing_window",
  "agent_servers": {
    "claude-acp": {
      "type": "custom",
      "command": "claude-agent-acp",
      "args": [],
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "claude",
      },
    },
    "codex-acp": {
      "type": "custom",
      "command": "codex-acp",
      "args": [],
      "env": {},
    },
  },
  "project_panel": {
    "dock": "left",
  },
  "outline_panel": {
    "dock": "left",
  },
  "collaboration_panel": {
    "dock": null,
    "button": false,
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": [],
  },
  "git_panel": {
    "dock": "left",
    "file_icons": true,
    "diff_stats": true,
    "folder_icons": true,
    "show_count_badge": true,
  },
  "edit_predictions": {
    "provider": "copilot",
    "disabled_globs": ["**/.env", "**/.env.*"],
  },
  "auto_update": false,
  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "load_direnv": "shell_hook",
  "show_whitespaces": "trailing",
  "relative_line_numbers": "enabled",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "off",
  "soft_wrap": "none",
  "minimap": {
    "show": "never",
  },
  "ui_font_size": 15.5,
  "ui_font_features": {
    "lida": true,
    "calt": true,
  },
  "status_bar": {
    "active_encoding_button": "enabled",
    "active_language_button": true,
    "cursor_position_button": true,
    "line_endings_button": true,
    "show_active_file": true,
  },
  "buffer_font_size": 14.5,
  "agent_buffer_font_size": 14.5,
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_weight": 450,
  "buffer_line_height": "standard",
  "auto_signature_help": true,
  "title_bar": {
    "show_branch_status_icon": true,
    "show_menus": false,
    "show_user_picture": false,
    "show_user_menu": false,
    "show_onboarding_banner": false,
    "show_sign_in": false,
  },
  "which_key": {
    "enabled": true,
  },
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "theme_overrides": {
    "Catppuccin Macchiato": {
      "syntax": {
        "property": {
          "color": "#b7bdf8",
        },
        "attribute.jsx": {
          "color": "#eed49f",
        },
        "tag.component.jsx": {
          "color": "#f5bde6",
        },
      },
    },
  },
  "semantic_tokens": "combined",
  "global_lsp_settings": {
    "semantic_token_rules": [
      {
        "token_type": "variable",
        "token_modifiers": ["readonly", "local"],
        "foreground_color": "#f5a97f",
      },
      {
        "token_type": "parameter",
        "foreground_color": "#ee99a0",
      },
      {
        "token_type": "function",
        "token_modifiers": ["defaultLibrary"],
        "style": ["function"],
      },
      {
        "token_type": "method",
        "token_modifiers": ["defaultLibrary"],
        "style": ["function"],
      },
      {
        "token_type": "enum",
        "style": ["type"],
      },
      {
        "token_type": "enumMember",
        "foreground_color": "#8bd5ca",
      },
    ],
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "nix": true,
    "lua": true,
    "harper": true,
  },
  "inlay_hints": {
    "enabled": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_type_hints": false,
    "show_value_hints": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "off",
    "copy_on_select": true,
    "dock": "bottom",
    "font_family": "Iosevka Nerd Font",
    "font_size": 14,
    "line_height": "standard",
    "shell": "system",
    "working_directory": "current_project_directory",
  },
  "node": {},
  "lsp": {},
  "languages": {},
}
