{
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  },
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "agent": {
    "dock": "right",
    "favorite_models": [],
    "model_parameters": []
  },
  "git_panel": {
    "dock": "left"
  },
  "features": {
    "edit_prediction_provider": "copilot",
  },
  "edit_predictions": {
    "disabled_globs": [],
  },
  "auto_update": false,
  "base_keymap": "VSCode",
  "vim_mode": true,
  "vim": {
    "use_system_clipboard": "always",
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": false,
  },
  "telemetry": {
    "diagnostics": false,
    "metrics": false,
  },
  "load_direnv": "shell_hook",
  "show_whitespaces": "trailing",
  "relative_line_numbers": "enabled",
  "remove_trailing_whitespace_on_save": true,
  "ensure_final_newline_on_save": true,
  "format_on_save": "on",
  "soft_wrap": "none",
  "minimap": {
    "show": "never",
  },
  "ui_font_size": 16.5,
  "ui_font_features": {
    "lida": true,
    "calt": true,
  },
  "buffer_font_size": 14,
  "buffer_font_family": "Iosevka Nerd Font",
  "buffer_font_weight": 450,
  "buffer_line_height": "standard",
  "theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato (lavender)",
  },
  "icon_theme": {
    "mode": "dark",
    "light": "Catppuccin Latte",
    "dark": "Catppuccin Macchiato",
  },
  "auto_install_extensions": {
    "catppuccin": true,
    "catppuccin-icons": true,
    "cspell": true,
    "html": true,
    "lua": true,
    "markdown-oxide": true,
    "marksman": true,
    "nix": true,
  },
  "inlay_hints": {
    "enabled": true,
    "show_parameter_hints": true,
    "show_other_hints": true,
    "show_type_hints": false,
    "show_value_hints": true,
  },
  "tabs": {
    "file_icons": true,
    "git_status": true,
    "show_diagnostics": "all",
  },
  "terminal": {
    "alternate_scroll": "off",
    "blinking": "off",
    "copy_on_select": true,
    "dock": "bottom",
    "font_family": "Iosevka Nerd Font",
    "font_size": 14,
    "line_height": "standard",
    "shell": "system",
    "working_directory": "current_project_directory",
  },
  "node": {},
  "lsp": {
    "bash-language-server": {
      "binary": {},
    },
    "cspell": {
      "settings": {
        "cSpell": {
          "language": "en,ru",
          "globalSettings": true,
        },
      },
    },
    "eslint": {
      "binary": {},
      "settings": {
        "codeActionOnSave": {
          "enable": true,
        },
        "problems": {
          "shortenToSingleLine": true,
        },
        "workingDirectory": {
          "mode": "auto",
        },
      },
    },
    "lua-language-server": {
      "binary": {},
      "settings": {
        "Lua": {
          "codeLens": {
            "enable": true,
          },
          "hint": {
            "enable": true,
          },
          "workspace": {
            "checkThirdParty": "Disable",
          },
        },
      },
    },
    "marksman": {
      "binary": {},
    },
    "nix": {
      "binary": {},
      "settings": {
        "nixd": {
          "formatting": {
            "command": ["nixfmt"],
          },
        },
      },
    },
    "tailwindcss-language-server": {
      "binary": {},
    },
    "typescript-language-server": {
      "binary": {},
      "initialization_options": {
        "preferences": {
          "includeInlayParameterNameHints": "all",
          "includeInlayParameterNameHintsWhenArgumentMatchesName": true,
          "includeInlayFunctionParameterTypeHints": false,
          "includeInlayVariableTypeHints": false,
          "includeInlayVariableTypeHintsWhenTypeMatchesName": false,
          "includeInlayPropertyDeclarationTypeHints": false,
          "includeInlayFunctionLikeReturnTypeHints": false,
          "includeInlayEnumMemberValueHints": false,
        },
      },
    },
    "vtsls": {
      "binary": {},
      "settings": {
        "javascript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": {
              "enabled": false,
            },
            "variableTypes": {
              "enabled": false,
            },
            "propertyDeclarationTypes": {
              "enabled": false,
            },
            "functionLikeReturnTypes": {
              "enabled": false,
            },
            "enumMemberValues": {
              "enabled": false,
            },
          },
          "tsserver": {
            "maxTsServerMemory": 4096,
          },
        },
        "typescript": {
          "inlayHints": {
            "parameterNames": {
              "enabled": "all",
              "suppressWhenArgumentMatchesName": true,
            },
            "parameterTypes": {
              "enabled": false,
            },
            "variableTypes": {
              "enabled": false,
            },
            "propertyDeclarationTypes": {
              "enabled": false,
            },
            "functionLikeReturnTypes": {
              "enabled": false,
            },
            "enumMemberValues": {
              "enabled": false,
            },
          },
          "tsserver": {
            "maxTsServerMemory": 4096,
          },
        },
      },
    },
    "vscode-css-language-server": {
      "binary": {},
    },
    "vscode-html-language-server": {
      "binary": {},
    },
    "yaml-language-server": {
      "binary": {},
      "settings": {
        "yaml": {
          "format": {
            "singleQuote": false,
          },
          "schemaStore": {
            "enable": true,
          },
          "validate": true,
        },
      },
    },
  },
  "languages": {
    "CSS": {
      "language_servers": [
        "vscode-css-language-server",
        "tailwindcss-language-server",
        "cspell",
        "...",
      ],
    },
    "HTML": {
      "language_servers": [
        "vscode-html-language-server",
        "tailwindcss-language-server",
        "cspell",
        "...",
      ],
    },
    "JavaScript": {
      "language_servers": ["vtsls", "eslint", "cspell", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "Lua": {
      "language_servers": ["lua-language-server", "cspell", "..."],
      "formatter": "language_server",
      "inlay_hints": {
        "enabled": true,
        "show_parameter_hints": true,
        "show_type_hints": true,
        "show_other_hints": true,
      },
    },
    "Markdown": {
      "language_servers": ["marksman", "markdown-oxide", "cspell", "..."],
      "format_on_save": "on",
    },
    "Nix": {
      "language_servers": ["nix", "cspell", "..."],
      "formatter": {
        "external": {
          "command": "nixfmt",
          "arguments": ["--filename", "{buffer_path}"],
        },
      },
    },
    "Shell Script": {
      "language_servers": ["bash-language-server", "cspell", "..."],
      "formatter": {
        "external": {
          "command": "shfmt",
          "arguments": ["--filename", "{buffer_path}", "--indent", "2"],
        },
      },
    },
    "TSX": {
      "language_servers": [
        "vtsls",
        "eslint",
        "tailwindcss-language-server",
        "cspell",
        "...",
      ],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "TypeScript": {
      "language_servers": ["vtsls", "eslint", "cspell", "..."],
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "YAML": {
      "language_servers": ["yaml-language-server", "cspell", "..."],
      "formatter": "language_server",
    },
  },
}
